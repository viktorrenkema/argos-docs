/**
 * Button reset - using :where to reduce specificity to 0
 * allowing overrides from utilities and other css modules
 */
:where(.button) {
  /** reset browser button styles */
  align-items: center;
  appearance: none;
  flex-basis: auto;
  flex-direction: row;
  flex-grow: 0;
  flex-shrink: 0;
  justify-content: center;
  outline: none;
  user-select: none;
  text-decoration-line: none;
}

.button {
  border-radius: 6px;
  height: var(--button-size);
  display: flex;
  gap: theme(spacing.2);
  font-family: theme(fontFamily.sans);
  @apply transition;
  padding-inline: var(--padding-inline-size, theme(spacing.3));
  & > * {
    @apply transition-opacity;
  }
}

.button[data-pressed="true"],
.button:active {
  transform: scale(0.98);

  /* & > * {
        opacity: 0.3;
    } */
}

.button:focus {
  outline: none;
}

.button[data-focus-visible="true"]:focus {
  box-shadow: theme(boxShadow.focus-ring);
  outline: transparent solid 2px;
}

.skeleton {
  visibility: hidden;
}

/* Variations */
.primary,
.merge,
.success,
.danger,
.upgrade {
  color: var(--sp-color-bg-base);
  /* Standard shadow on the primary btn */
  --shadow: rgba(0, 0, 0, 0.05);
  --shadow-2: rgba(31, 41, 51, 0.06);
  box-shadow:
            /* Shadow */ 0px 2px 2px 0px var(--shadow),
    0px 8px 14px 3px var(--shadow-2),
    /* Inner top and bottom border shadows */ inset 0 -1px 0.4px 0 rgba(0, 0, 0, 0.2),
    inset 0 1px 0.4px 0 #ffffff33;
}

.primary:hover,
.merge:hover,
.success:hover,
.danger:hover,
.upgrade:hover {
  /* Increased shadow on hover for primary btn */
  --shadow: rgba(0, 0, 0, 0.12);
  --shadow-2: rgba(31, 41, 51, 0.1);
  box-shadow: 0px 2px 2px 0px var(--shadow), 0px 8px 14px 3px var(--shadow-2),
    /* Inner top and bottom border shadows */ inset 0 -1px 0.4px 0 rgba(0, 0, 0, 0.2),
    inset 0 1px 0.4px 0 #ffffff33;
}

.button:not(.secondary)[data-pressed="true"],
.button:not(.secondary):active {
  box-shadow: 0px 0px 0px 0px var(--shadow), 0px 0px 0px 0px var(--shadow-2),
    inset 0 -1px 0.4px 0 rgba(0, 0, 0, 0.2), inset 0 1px 0.4px 0 #ffffff33;
}

/* Primary */
.primary {
  background-color: var(--sp-color-action-bg-primary-default);
}
.primary:hover {
  background: var(--sp-color-primary-600);
}
